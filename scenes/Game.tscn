resource_name = "gameover"
script/source = "extends Control

var hold_time = 0.0
var is_holding = false
var required_hold = 1.0

func _ready():
	get_node(\"Button\").hide()
	get_node(\"ColorRect\").hide()
	get_node(\"Bybotysfy\").hide()
	get_node(\"Cop\").hide()

func start(scores):
	show()
	get_node(\"ColorRect\").show()
	get_node(\"Bybotysfy\").show()
	get_node(\"Cop\").show()
	get_node(\"AnimationPlayer\").play(\"GameOver\")
	get_node(\"Timer\").start()
	mostrar_tabla(scores)

func mostrar_tabla(scores):
	var jugadores = [\"Jugador 1\", \"Jugador 2\", \"Jugador 3\"]
	
	var ranking = []
	for i in range(3):
		ranking.append({\"nombre\": jugadores[i], \"puntos\": scores[i]})
	
	ranking.sort_custom(self, \"ordenar_por_puntos\")
	
	var medallas = [\"1ro\", \"2do\", \"3ro\"]
	var texto = \"FIN DEL JUEGO\\n\\n\"
	for i in range(ranking.size()):
		texto += medallas[i] + \"  \" + ranking[i][\"nombre\"] + \":  $\" + str(ranking[i][\"puntos\"]) + \"\\n\\n\"
	
	var label = get_node(\"Label\")
	label.set_text(texto)
	label.align = Label.ALIGN_CENTER
	label.rect_size = Vector2(540, 600)
	label.rect_scale = Vector2(0.8, 0.6)
	label.rect_position = Vector2(520, 1950)
	
func ordenar_por_puntos(a, b):
	return a[\"puntos\"] > b[\"puntos\"]

func _on_Timer_timeout():
	get_node(\"Button\").show()

func _process(delta):
	if is_holding:
		hold_time += delta
		if hold_time >= required_hold:
			get_tree().reload_current_scene()

func _on_Button_button_down():
	is_holding = true
	hold_time = 0.0

func _on_Button_button_up():
	is_holding = false
	hold_time = 0.0
"

